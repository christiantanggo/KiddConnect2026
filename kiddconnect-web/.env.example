# Override API base (Vercel Production). If unset, next.config uses Railway default in repo.
# NEXT_PUBLIC_API_URL=https://kiddconnect2026-production.up.railway.app
# NEXT_PUBLIC_API_URL=https://api.kiddconnect.ca

# Site title + dashboard copy (defaults to KiddConnect in lib/appBrand.js).
# If Vercel still shows "Tavari", remove NEXT_PUBLIC_APP_DISPLAY_NAME or set:
# NEXT_PUBLIC_APP_DISPLAY_NAME=KiddConnect
# NEXT_PUBLIC_APP_DESCRIPTION=KiddConnect — YouTube studio tools for creators
